 /// Swaps USDC for WETH on Base (chain id 8453).
 contract SwapOnBase {
     IERC20 public constant USDC = IERC20(0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913);
     IERC20 public constant WETH = IERC20(0x4200000000000000000000000000000000000006);
+    ISwapRouter02 public constant ROUTER = ISwapRouter02(0x2626664c2603336E57B271c5C0b26F421741e481);
+
+    uint24 public constant USDC_WETH_POOL_FEE = 500;
 
     /// Pull `amountIn` USDC from the caller, swap it for at least `minOut` WETH,
     /// and send the WETH to the caller.
     function swapUsdcForWeth(uint256 amountIn, uint256 minOut) external returns (uint256 amountOut) {
-        // TODO: implement
+        require(USDC.transferFrom(msg.sender, address(this), amountIn), "USDC transfer failed");
+        require(USDC.approve(address(ROUTER), amountIn), "USDC approve failed");
+
+        ISwapRouter02.ExactInputSingleParams memory params = ISwapRouter02.ExactInputSingleParams({
+            tokenIn: address(USDC),
+            tokenOut: address(WETH),
+            fee: USDC_WETH_POOL_FEE,
+            recipient: msg.sender,
+            amountIn: amountIn,
+            amountOutMinimum: minOut,
+            sqrtPriceLimitX96: 0
+        });
+
+        amountOut = ROUTER.exactInputSingle(params);
     }
 }

