 /// Swaps USDC for WETH on Base (chain id 8453).
 contract SwapOnBase {
     IERC20 public constant USDC = IERC20(0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913);
     IERC20 public constant WETH = IERC20(0x4200000000000000000000000000000000000006);
+    IAerodromeRouter public constant ROUTER = IAerodromeRouter(0xcF77A3bA9a5Ca399b7C97c74d54e5b4DA9F7Cf0D);
+
+    address public constant AERODROME_POOL_FACTORY = 0x420Dd381b31aEF6683db6B902084cb0FFeEc8Fda;
 
     /// Pull `amountIn` USDC from the caller, swap it for at least `minOut` WETH,
     /// and send the WETH to the caller.
     function swapUsdcForWeth(uint256 amountIn, uint256 minOut) external returns (uint256 amountOut) {
-        // TODO: implement
+        require(amountIn > 0, "amountIn=0");
+
+        _requireSuccess(USDC.transferFrom(msg.sender, address(this), amountIn), "USDC transferFrom failed");
+        _requireSuccess(USDC.approve(address(ROUTER), amountIn), "USDC approve failed");
+
+        IAerodromeRouter.Route[] memory routes = new IAerodromeRouter.Route[](1);
+        routes[0] = IAerodromeRouter.Route({
+            from: address(USDC),
+            to: address(WETH),
+            stable: false,
+            factory: AERODROME_POOL_FACTORY
+        });
+
+        uint256 wethBefore = WETH.balanceOf(address(this));
+        ROUTER.swapExactTokensForTokens(amountIn, minOut, routes, address(this), block.timestamp);
+        amountOut = WETH.balanceOf(address(this)) - wethBefore;
+
+        require(amountOut >= minOut, "insufficient WETH out");
+        _requireSuccess(WETH.transfer(msg.sender, amountOut), "WETH transfer failed");
+        _requireSuccess(USDC.approve(address(ROUTER), 0), "USDC approve reset failed");
+    }
+
+    function _requireSuccess(bool success, string memory errorMessage) private pure {
+        require(success, errorMessage);
     }
