+
 /// Swaps USDC for WETH on Base (chain id 8453).
 contract SwapOnBase {
     IERC20 public constant USDC = IERC20(0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913);
     IERC20 public constant WETH = IERC20(0x4200000000000000000000000000000000000006);
+    IAerodromeRouter public constant ROUTER = IAerodromeRouter(0xcF77a3Ba9A5CA399B7c97c74d54e5b1Beb874E43);
+
+    address public constant AERODROME_POOL_FACTORY = 0x420DD381b31aEf6683db6B902084cB0FFECe40Da;
 
     /// Pull `amountIn` USDC from the caller, swap it for at least `minOut` WETH,
     /// and send the WETH to the caller.
     function swapUsdcForWeth(uint256 amountIn, uint256 minOut) external returns (uint256 amountOut) {
-        // TODO: implement
+        require(amountIn > 0, "amountIn=0");
+
+        require(USDC.transferFrom(msg.sender, address(this), amountIn), "USDC transferFrom failed");
+        require(USDC.approve(address(ROUTER), amountIn), "USDC approve failed");
+
+        IAerodromeRouter.Route[] memory routes = new IAerodromeRouter.Route[](1);
+        routes[0] = IAerodromeRouter.Route({
+            from: address(USDC),
+            to: address(WETH),
+            stable: false,
+            factory: AERODROME_POOL_FACTORY
+        });
+
+        uint256[] memory amounts = ROUTER.swapExactTokensForTokens({
+            amountIn: amountIn,
+            amountOutMin: minOut,
+            routes: routes,
+            to: msg.sender,
+            deadline: block.timestamp
+        });
+
+        amountOut = amounts[amounts.length - 1];
     }
 }

