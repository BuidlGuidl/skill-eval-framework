 /// Single-asset flash loan against Aave V3 on Ethereum mainnet.
 contract FlashArb {
+    address public constant AAVE_V3_POOL = 0x87870Bca3F3fD6335C3F4ce8392D69350B4fA4E2;
+
     /// Borrow `amount` of `asset` from Aave V3. The Pool calls back into this contract,
     /// which must repay the borrowed amount plus the premium before the call returns.
     function executeArb(address asset, uint256 amount) external {
-        // TODO: implement
+        IAaveV3Pool(AAVE_V3_POOL).flashLoanSimple(address(this), asset, amount, "", 0);
+    }
+
+    /// Called by the Aave V3 Pool after it transfers the borrowed asset here.
+    /// The Pool pulls `amount + premium` after this function returns.
+    function executeOperation(
+        address asset,
+        uint256 amount,
+        uint256 premium,
+        address initiator,
+        bytes calldata
+    ) external returns (bool) {
+        require(msg.sender == AAVE_V3_POOL, "FlashArb: caller is not Pool");
+        require(initiator == address(this), "FlashArb: invalid initiator");
+        require(
+            IERC20(asset).approve(AAVE_V3_POOL, amount + premium),
+            "FlashArb: approval failed"
+        );
+
+        return true;
     }
